{
  "name": "ocelot-ui",
  "version": "0.0.15",
  "license": "MIT",
  "author": "Rick Bairstow <rick@rxdesign.co.uk> (https://www.rxdesign.co.uk)",
  "description": "Ocelot UI (OUI), a UI framework built with Vue 3 and Tailwind CSS, is designed to be highly performant, optimized, and accessible. It strikes a balance by providing essential features without being overly opinionated, allowing for flexibility in your projects.",
  "homepage": "https://github.com/rickbairstow/Ocelot",
  "keywords": [
    "component library",
    "vue",
    "tailwind"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickbairstow/Ocelot.git"
  },
  "bugs": {
    "url": "https://github.com/rickbairstow/Ocelot/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "tailwind.css"
  ],
  "main": "./dist/ocelot-ui.umd.js",
  "module": "./dist/ocelot-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/ocelot-ui.es.js",
      "require": "./dist/ocelot-ui.umd.js"
    },
    "./style.css": "./dist/style.css",
    "./tailwind.css": "./tailwind.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run eslint && npm run stylelint",
    "lint:fix": "npm run eslint:fix && npm run stylelint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "stylelint": "stylelint **/*.css **/*.scss",
    "stylelint:fix": "stylelint **/*.css **/*.scss --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "upgrade-storybook": "npx storybook@latest upgrade",
    "test-storybook": "test-storybook",
    "test": "vitest",
    "test:run": "vitest run",
    "publish:npm": "node .build/publish.mjs"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tabler/icons": "^3.41.1",
    "@tabler/icons-vue": "^3.41.1",
    "culori": "^4.0.2",
    "photoswipe": "^5.4.4",
    "plyr": "^3.8.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/test-runner": "^0.24.3",
    "@storybook/vue3-vite": "^10.3.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-storybook": "^10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "sass-embedded": "^1.99.0",
    "storybook": "^10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.2",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "storybook": "$storybook"
  }
}
