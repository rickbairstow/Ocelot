{
    "extends": [
        "stylelint-config-standard",
        "stylelint-config-standard-scss"
    ],
    "ignoreFiles": [
        "dist/**/*.css",
        "storybook-static/**/*.css"
    ],
    "rules": {
        "scss/at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": [
                    "apply",
                    "custom-variant",
                    "layer",
                    "responsive",
                    "screen",
                    "source",
                    "tailwind",
                    "variants"
                ]
            }
        ]
    }
}
